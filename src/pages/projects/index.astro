---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  PROJECT_TIERS,
  PROJECT_TRACKS,
  TIER_LABELS,
  TRACK_LABELS,
  type ProjectTier,
  type ProjectTrack,
} from '../../lib/projects/schema';
import ProjectSubmittedMarkers from '../../components/projects/ProjectSubmittedMarkers';

const allProjects = await getCollection('projects');

// Group: tier -> track -> projects[]
const grouped = new Map<ProjectTier, Map<ProjectTrack, typeof allProjects>>();
for (const tier of PROJECT_TIERS) {
  const trackMap = new Map<ProjectTrack, typeof allProjects>();
  for (const track of PROJECT_TRACKS) trackMap.set(track, []);
  grouped.set(tier, trackMap);
}
for (const p of allProjects) {
  grouped.get(p.data.tier)!.get(p.data.track)!.push(p);
}
for (const trackMap of grouped.values()) {
  for (const list of trackMap.values()) {
    list.sort((a, b) => a.data.title.localeCompare(b.data.title));
  }
}

const tierEstimate: Record<ProjectTier, string> = {
  starter: '1–2 hr',
  mid: '~1 day',
  capstone: '~1 week',
};

const tierBlurb: Record<ProjectTier, string> = {
  starter: 'Pick a tool, ship a tiny suite. One focused diagnostic skill.',
  mid: 'Combine two concepts, harness real CI. Multiple moving parts.',
  capstone: 'Production-grade artifact. A full QA artifact for the resume.',
};

const tierProofNote: Record<ProjectTier, string> = {
  starter: 'Self-attest checklist',
  mid: 'Public repo URL required',
  capstone: 'Public repo + green CI required',
};
---

<BaseLayout
  title="Build — Project Briefs — QA Learning"
  description={`Tiered QA project briefs: ${allProjects.length} projects across Starter, Mid, and Capstone tiers.`}
>
  <section class="hero">
    <div>
      <span class="eyebrow">build pillar · self-directed</span>
      <h1>
        Read less.<br />
        Build <em>more.</em>
      </h1>
      <p class="hero__lead">
        Three tiers of self-directed project briefs organised into skill tracks.
        Each brief ships with scoped acceptance criteria, a self-check rubric,
        and tier-gated proof of done.
      </p>
    </div>
    <div class="card" style="align-self: end; padding: 22px; font-size: 13px; color: var(--ink-2); line-height: 1.6;">
      <div class="eyebrow" style="margin-bottom: 10px;">tiers &amp; proof of done</div>
      {PROJECT_TIERS.map((tier) => (
        <div style="margin-top: 6px;">
          <strong style="color: var(--ink);">{TIER_LABELS[tier]}</strong> · {tierEstimate[tier]} ·{' '}
          <span style="color: var(--ink-3);">{tierProofNote[tier]}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    {PROJECT_TIERS.map((tier) => {
      const trackMap = grouped.get(tier)!;
      const tierProjects = [...trackMap.values()].flat();
      if (tierProjects.length === 0) return null;

      return (
        <div style="margin-bottom: 56px;">
          <div style="display: flex; align-items: baseline; gap: 14px; margin-bottom: 8px;">
            <h2
              style="font-family: var(--serif); font-size: 32px; font-weight: 400; letter-spacing: -0.02em; margin: 0; color: var(--ink); line-height: 1.15;"
            >
              {TIER_LABELS[tier]}
            </h2>
            <span class="pill">{tierEstimate[tier]}</span>
            <span class="pill">{tierProjects.length} brief{tierProjects.length === 1 ? '' : 's'}</span>
          </div>
          <p style="font-size: 13px; color: var(--ink-2); margin: 0 0 24px; line-height: 1.55;">
            {tierBlurb[tier]} · <em style="color: var(--ink-3);">{tierProofNote[tier]}</em>
          </p>

          {PROJECT_TRACKS.map((track) => {
            const list = trackMap.get(track)!;
            if (list.length === 0) return null;
            return (
              <div style="margin-bottom: 32px;">
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 14px;">
                  <span class="eyebrow" style="font-size: 10px; letter-spacing: 0.1em;">{TRACK_LABELS[track]}</span>
                  <span style="flex: 1; height: 1px; background: var(--rule);"></span>
                </div>
                <div class="brief-grid">
                  {list.map((project, i) => (
                    <a class="brief-card" href={`/projects/${project.data.slug}`} data-project-slug={project.data.slug}>
                      <div class="brief-card__head">
                        <div class="eyebrow">brief · {String(i + 1).padStart(2, '0')}</div>
                        <span class="brief-card__submitted" data-testid="brief-submitted-badge" hidden>
                          ✓ submitted
                        </span>
                      </div>
                      <div class="brief-card__title">{project.data.title}</div>
                      <div class="brief-card__desc">
                        {project.data.acceptanceCriteria.length} acceptance criteria · {TIER_LABELS[tier]}
                      </div>
                      <div class="brief-card__foot">
                        <span class="mono" style="font-size: 11px; color: var(--ink-3);">
                          {project.data.estimate}
                        </span>
                        <span class="mono" style="font-size: 12px; color: var(--ink); text-decoration: underline;">
                          open brief →
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      );
    })}
  </section>
  <ProjectSubmittedMarkers client:idle />
</BaseLayout>

<style>
  .brief-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 1024px) { .brief-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px)  { .brief-grid { grid-template-columns: 1fr; } }

  .brief-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 200px;
    padding: 22px;
    border: 1px solid var(--rule);
    border-radius: 12px;
    background: var(--paper);
    text-decoration: none;
    color: var(--ink);
    transition: border-color 150ms ease, background 150ms ease;
  }
  .brief-card:hover { border-color: var(--ink-3); background: var(--paper-2); }
  .brief-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .brief-card__submitted {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--pass-strong);
    border: 1px solid var(--pass);
    border-radius: 999px;
    padding: 2px 8px;
    white-space: nowrap;
  }
  .brief-card__title {
    font-family: var(--serif);
    font-size: 22px;
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--ink);
    font-weight: 450;
  }
  .brief-card__desc {
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.55;
  }
  .brief-card__foot {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 14px;
    border-top: 1px solid var(--rule);
  }
</style>
