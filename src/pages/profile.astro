---
import BaseLayout from '../layouts/BaseLayout.astro';
import Heatmap from '../components/profile/Heatmap.astro';
import SubmissionsList from '../components/profile/SubmissionsList';
import { auth } from '../lib/auth';
import {
  getCategoryProgress,
  getCompletedLessonCount,
  getHeatmap,
  getQuizAccuracyByTopic,
  getQuizAttemptCount,
  getStreak,
  listSubmissions,
} from '../db/queries';

export const prerender = false;

const session = await auth.api.getSession({ headers: Astro.request.headers });
const user = session?.user ?? null;
const completedCount = user?.id ? await getCompletedLessonCount(user.id) : 0;
const attemptCount = user?.id ? await getQuizAttemptCount(user.id) : 0;
const streak = user?.id ? await getStreak(user.id) : { current: 0, longest: 0 };
const submissions = user?.id ? await listSubmissions(user.id) : [];
const categoryProgress = user?.id ? await getCategoryProgress(user.id) : [];
const quizAccuracy = user?.id ? await getQuizAccuracyByTopic(user.id) : [];
const heatmapYear = new Date().getUTCFullYear();
const heatmapCells = user?.id ? await getHeatmap(user.id, heatmapYear) : [];
const submissionsProp = submissions.map((s) => ({
  projectSlug: s.projectSlug,
  repoUrl: s.repoUrl,
  reflection: s.reflection,
  isPublic: s.isPublic,
  submittedAt: s.submittedAt.toISOString(),
}));

function initials(name: string | null | undefined, email: string | null | undefined): string {
  const src = (name ?? email ?? '').trim();
  if (!src) return '·';
  const parts = src.split(/\s+/).filter(Boolean);
  if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
  return src.slice(0, 2).toUpperCase();
}

function formatCategory(cat: string): string {
  return cat.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

const totalCorrect = quizAccuracy.reduce((s, t) => s + t.correct, 0);
const totalQ = quizAccuracy.reduce((s, t) => s + t.total, 0);
const overallAccuracy = totalQ > 0 ? Math.round((totalCorrect / totalQ) * 100) : 0;
const totalLessons = categoryProgress.reduce((s, c) => s + c.total, 0);
---

<BaseLayout title="Profile — QA Learning">
  <main class="profile">
    {user ? (
      <>
        <section class="identity">
          <div class="identity__left">
            <div class="avatar avatar--lg">{initials(user.name, user.email)}</div>
            <div>
              <span class="eyebrow">profile · private</span>
              <div class="identity__name">{user.name ?? user.email}</div>
              <div class="identity__email">{user.email}</div>
            </div>
          </div>
          <div class="identity__stats">
            <div class="istat">
              <div class="istat__num">
                {streak.current}
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--accent); margin-left: 6px;">
                  <path d="M12 2s4 4 4 8a4 4 0 0 1-8 0c0-2 1-3 1-3s-3 2-3 6a6 6 0 0 0 12 0c0-6-6-11-6-11z" />
                </svg>
              </div>
              <div class="eyebrow" data-testid="streak-current">day streak · {streak.longest} longest</div>
            </div>
            <div class="istat">
              <div class="istat__num" data-testid="completed-count">
                {completedCount}<span class="istat__num-sub">/{totalLessons || '—'}</span>
              </div>
              <div class="eyebrow">lessons done</div>
            </div>
            <div class="istat">
              <div class="istat__num" data-testid="attempt-count">
                {overallAccuracy}<span class="istat__num-sub">%</span>
              </div>
              <div class="eyebrow">quiz accuracy · {attemptCount} attempts</div>
            </div>
          </div>
        </section>

        <section class="profile-grid">
          <div class="profile-grid__wide">
            <Heatmap cells={heatmapCells} year={heatmapYear} />
          </div>

          <div class="card profile-grid__wide" data-testid="category-progress-section" aria-label="Category progress">
            <span class="eyebrow">progress by track</span>
            {categoryProgress.length === 0 ? (
              <p style="color: var(--ink-3); font-size: 14px; margin-top: 12px;">No lessons yet. Pick one from the home page.</p>
            ) : (
              <div style="display: grid; gap: 14px; margin-top: 16px;">
                {categoryProgress.map((cp) => (
                  <div
                    style="display: grid; grid-template-columns: 180px 1fr 60px; align-items: center; gap: 16px;"
                    data-testid={`category-progress-${cp.category}`}
                  >
                    <div style="font-size: 13px; font-weight: 500; color: var(--ink);">
                      {formatCategory(cp.category)}
                    </div>
                    <div
                      style="height: 8px; background: var(--paper-3); border-radius: 4px; overflow: hidden;"
                      role="progressbar"
                      aria-valuenow={cp.percent}
                      aria-valuemin="0"
                      aria-valuemax="100"
                      aria-label={`${cp.category} ${cp.percent}% complete`}
                    >
                      <div style={`width: ${cp.percent}%; height: 100%; background: ${cp.percent > 50 ? 'var(--accent)' : cp.percent > 0 ? 'oklch(75% 0.13 35)' : 'transparent'};`}></div>
                    </div>
                    <div style="font-family: var(--mono); font-size: 11px; color: var(--ink-3); text-align: right;">
                      {cp.completed}/{cp.total}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>

          <div class="card" data-testid="submissions-section" aria-label="Project submissions">
            <span class="eyebrow">portfolio · projects shipped</span>
            <div style="margin-top: 14px;">
              <SubmissionsList client:load submissions={submissionsProp} />
            </div>
          </div>

          <div class="card profile-grid__wide" data-testid="quiz-accuracy-section" aria-label="Quiz accuracy by topic">
            <span class="eyebrow">quiz accuracy · weakest first</span>
            {quizAccuracy.length === 0 ? (
              <p style="color: var(--ink-3); font-size: 14px; margin-top: 12px;">No quiz attempts yet.</p>
            ) : (
              <>
                <div style="display: grid; gap: 12px; margin-top: 16px;">
                  {quizAccuracy.map((t) => (
                    <div
                      style="display: grid; grid-template-columns: 200px 50px 1fr 80px; align-items: center; gap: 14px; font-size: 13px;"
                      data-testid={`quiz-accuracy-${t.category}`}
                    >
                      <span style="font-weight: 500; color: var(--ink);">{formatCategory(t.category)}</span>
                      <span style={`font-family: var(--mono); color: ${t.accuracy < 70 ? 'var(--accent)' : 'var(--ink-2)'}`}>
                        {t.accuracy}%
                      </span>
                      <div style="height: 6px; background: var(--paper-3); border-radius: 3px; position: relative;">
                        <div style={`width: ${t.accuracy}%; height: 100%; background: ${t.accuracy < 70 ? 'var(--accent)' : 'var(--pass)'}; border-radius: 3px;`}></div>
                        <div style="position: absolute; left: 65%; top: -3px; height: 12px; width: 1px; background: var(--ink-3);"></div>
                      </div>
                      <span style="font-family: var(--mono); font-size: 11px; color: var(--ink-3); text-align: right;">
                        {t.correct}/{t.total}
                      </span>
                    </div>
                  ))}
                </div>
                <div style="margin-top: 14px; font-size: 11px; font-family: var(--mono); color: var(--ink-3);">
                  ↳ vertical line: ISTQB pass threshold · 65%
                </div>
              </>
            )}
          </div>
        </section>
      </>
    ) : (
      <section class="signed-out">
        <span class="eyebrow">profile</span>
        <h1 style="font-family: var(--serif); font-weight: 400; font-size: 48px; letter-spacing: -0.03em; margin: 8px 0 14px; color: var(--ink);">
          Sign in to <em style="font-style: italic; color: var(--accent);">track progress.</em>
        </h1>
        <p style="font-size: 16px; color: var(--ink-2); max-width: 52ch; line-height: 1.55;">
          Lessons completed, quiz accuracy by topic, project submissions, and streaks — all kept against your account.
        </p>
        <div style="display: flex; gap: 12px; margin-top: 22px;">
          <a href="/api/auth/sign-in/github" class="btn btn--primary btn--lg">Sign in with GitHub</a>
          <a href="/api/auth/sign-in/google" class="btn btn--ghost btn--lg">Sign in with Google</a>
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .profile {
    padding: 44px 56px;
    max-width: 1240px;
    margin: 0 auto;
  }
  @media (max-width: 768px) { .profile { padding: 28px 20px; } }

  .identity {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 28px;
  }
  .identity__left { display: flex; gap: 20px; align-items: center; }
  .avatar--lg { width: 64px; height: 64px; font-size: 22px; }
  .identity__name {
    font-family: var(--serif);
    font-size: 38px;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-top: 4px;
    color: var(--ink);
  }
  .identity__email {
    font-size: 13px;
    color: var(--ink-3);
    font-family: var(--mono);
    margin-top: 4px;
  }
  .identity__stats { display: flex; gap: 32px; flex-wrap: wrap; }
  .istat__num {
    font-family: var(--serif);
    font-size: 44px;
    letter-spacing: -0.03em;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  .istat__num-sub { color: var(--ink-3); font-size: 24px; }

  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
  }
  .profile-grid__wide { grid-column: 1 / -1; }
  @media (max-width: 1024px) { .profile-grid { grid-template-columns: 1fr; } }

  .signed-out { padding: 64px 0; }
</style>
