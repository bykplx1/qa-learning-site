---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadReachableQuizzes } from '../lib/quiz/loadQuiz';
import { sortCurriculum, groupByCluster, clusterDisplay } from '../lib/curriculum/order';
import type { CurriculumEntry } from '../lib/curriculum/order';
import type { CurriculumCluster } from '../lib/curriculum/schema';
import { LessonCompletionMarkers } from '../components/lessons/LessonCompletionMarkers';

const allTopics = await getCollection('curriculum');
const sorted = sortCurriculum(allTopics);
const groups = groupByCluster(allTopics);

const clusterRows = Array.from(groups.entries())
  .filter(([, topics]) => topics.length > 0)
  .map(([cluster, topics]) => ({
    cluster,
    title: clusterDisplay(cluster),
    topics,
    count: topics.length,
    minutes: topics.reduce((s, t) => s + t.data.estimatedEncodingMinutes, 0),
  }));

const totalTopics = sorted.length;
const totalMinutes = sorted.reduce((s, t) => s + t.data.estimatedEncodingMinutes, 0);

const liveSlugs = new Set(sorted.map((t) => t.data.slug));
const reachableQuizzes = loadReachableQuizzes(liveSlugs);
const totalQuizQuestions = reachableQuizzes.reduce((sum, q) => sum + q.questions.length, 0);

const latestTopics = sorted.slice(0, 10);

function layerIndicator(layer: CurriculumEntry['data']['layer']): string {
  return layer === 'facts' ? 'b' : layer === 'patterns' ? 'i' : 'a';
}
---

<BaseLayout
  title="QA Learning"
  description={`Interactive study site for QA fundamentals. ${totalTopics} topics across ${clusterRows.length} tracks.`}
>
  <main id="main">
  <section class="hero">
    <div>
      <span class="eyebrow">QA · curriculum + practice</span>
      <h1>
        A QA curriculum,<br />
        built like <em>production code.</em>
      </h1>
      <p class="hero__lead">
        {totalTopics} hand-written topics across {clusterRows.length} tracks, with practice quizzes,
        a build pipeline of self-directed projects, and a profile that tracks what you've shipped.
        Open-source and statically generated.
      </p>
      <div class="hero__cta">
        <a href={`/lessons/${sorted[0]?.data.cluster ?? ''}/${sorted[0]?.data.slug ?? ''}`} class="btn btn--primary btn--lg">
          Start with {clusterRows[0]?.title ?? 'track 1'}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="/projects" class="btn btn--ghost btn--lg">
          Browse build briefs
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="/exam" class="btn btn--ghost btn--lg" data-testid="hero-exam-cta">
          Take mock exam
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        </a>
      </div>
    </div>
    <div class="hero__stats">
      <div class="hero__stat">
        <div class="num">{totalTopics}</div>
        <div class="lbl">Topics across {clusterRows.length} tracks</div>
      </div>
      <div class="hero__stat">
        <div class="num">{totalQuizQuestions}</div>
        <div class="lbl">Quiz questions</div>
      </div>
      <div class="hero__stat">
        <div class="num">{totalMinutes}<small>m</small></div>
        <div class="lbl">Total read time</div>
      </div>
      <div class="hero__stat">
        <div class="num num--accent">{clusterRows.length}</div>
        <div class="lbl">Curriculum tracks</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section__head">
      <div>
        <span class="eyebrow">curriculum</span>
        <h2>{clusterRows.length} tracks, ordered from the foundation up.</h2>
      </div>
      <p>
        Each track maps to a cluster in the curriculum. Topics are MDX, quizzes are YAML;
        every topic builds progressively from facts to patterns to systems.
      </p>
    </div>
    <div class="cat-grid" data-testid="curated-tracks">
      {clusterRows.map((c) => (
        <a
          class="cat"
          href={`/lessons/${c.topics[0].data.cluster}/${c.topics[0].data.slug}`}
          data-cluster={c.cluster}
          data-cluster-slugs={c.topics.map((t) => t.data.slug).join(',')}
        >
          <div class="cat__num">{c.cluster.toUpperCase()}</div>
          <div class="cat__title">{c.title}</div>
          <div class="cat__blurb">
            Start with <em style="font-style: italic;">{c.topics[0].data.title}</em>.
          </div>
          <div class="cat__bar">
            <div
              role="progressbar"
              aria-valuenow={0}
              aria-valuemin={0}
              aria-valuemax={c.count}
              aria-label={`${c.title} track progress`}
              style="width: 0%"
            ></div>
          </div>
          <div class="cat__meta">
            <span>{c.count} topic{c.count === 1 ? '' : 's'}</span>
            <span>{c.minutes}m read</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__head">
      <div>
        <span class="eyebrow">recent · ordered</span>
        <h2>Latest topics.</h2>
      </div>
      <a href="#all" class="btn btn--ghost">
        All {totalTopics} topics
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="lessons-list">
      {latestTopics.map((t, i) => {
        const diff = layerIndicator(t.data.layer);
        return (
          <a class="lrow" href={`/lessons/${t.data.cluster}/${t.data.slug}`}>
            <span class="lrow__idx">{i + 1}</span>
            <div class="lrow__title">
              {t.data.title}
              <small>{clusterDisplay(t.data.cluster as CurriculumCluster)}</small>
            </div>
            <span class="lrow__min">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              {t.data.estimatedEncodingMinutes}m
            </span>
            <span class={`lrow__diff diff-${diff}`} title={t.data.layer}></span>
          </a>
        );
      })}
    </div>
  </section>

  <section class="section" id="all">
    {clusterRows.map(({ cluster, topics }) => (
      <div style="margin-bottom: 40px;">
        <div class="section__head" style="margin-bottom: 16px;">
          <div>
            <span class="eyebrow">{cluster} · {topics.length} topic{topics.length === 1 ? '' : 's'}</span>
            <h2 style="font-size: 26px;">{clusterDisplay(cluster as CurriculumCluster)}</h2>
          </div>
        </div>
        <div class="lessons-list">
          {topics.map((t, i) => {
            const diff = layerIndicator(t.data.layer);
            return (
              <a class="lrow" href={`/lessons/${t.data.cluster}/${t.data.slug}`}>
                <span class="lrow__idx">{i + 1}</span>
                <div class="lrow__title">
                  {t.data.title}
                  <small>{t.data.tags.slice(0, 3).join(' · ')}</small>
                </div>
                <span class="lrow__min">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                  {t.data.estimatedEncodingMinutes}m
                </span>
                <span class={`lrow__diff diff-${diff}`} title={t.data.layer}></span>
              </a>
            );
          })}
        </div>
      </div>
    ))}
  </section>

  <LessonCompletionMarkers client:load />
  </main>
</BaseLayout>
