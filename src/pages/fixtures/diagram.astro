---
import Diagram from '../../components/mdx/Diagram.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Diagram fixture</title>
    <style>
      body { margin: 32px; font-family: sans-serif; background: #fff; color: #111; }
      .section { margin-bottom: 40px; }
      h2 { font-size: 14px; font-family: monospace; margin-bottom: 8px; }
    </style>
  </head>
  <body>
    <div class="section" id="mermaid-section">
      <h2>Mermaid diagram</h2>
      <Diagram src="graph TD; A[Start] --> B[Process]; B --> C[End]" caption="Simple flow graph" />
    </div>

    <div class="section" id="inline-svg-section">
      <h2>Inline SVG</h2>
      <Diagram caption="Inline SVG example">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="200"
          height="80"
          viewBox="0 0 200 80"
          role="img"
          aria-label="Two connected circles"
        >
          <circle cx="40" cy="40" r="30" fill="none" stroke="#666" stroke-width="2" />
          <circle cx="160" cy="40" r="30" fill="none" stroke="#666" stroke-width="2" />
          <line x1="70" y1="40" x2="130" y2="40" stroke="#666" stroke-width="2" />
          <text x="40" y="44" text-anchor="middle" font-size="12" fill="#333">A</text>
          <text x="160" y="44" text-anchor="middle" font-size="12" fill="#333">B</text>
        </svg>
      </Diagram>
    </div>

    <div class="section" id="skipped-section">
      <h2>Skipped (atomic-fact)</h2>
      <Diagram skip="atomic-fact" src="graph TD; X-->Y" caption="should not render" />
      <span id="skip-control">after-skip</span>
    </div>
  </body>
</html>
