---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ExamRunner from '../components/exam/ExamRunner';
import { buildExamPool } from '../lib/exam/pool';
import {
  EXAM_DURATION_MINUTES,
  EXAM_DURATION_MS,
  EXAM_SLUG,
} from '../lib/exam/config';

export const prerender = true;

const allTopics = await getCollection('curriculum');
const liveSlugs = new Set(allTopics.map((t) => t.data.slug));
const examQuestions = buildExamPool(liveSlugs);
---

<BaseLayout
  title="Mock exam — QA Learning"
  description={`${examQuestions.length}-question, ${EXAM_DURATION_MINUTES}-minute mock exam covering live curriculum topics.`}
>
  <div class="exam-page">
    <header class="exam-page__head">
      <h1>Mock exam</h1>
      <p class="lead">
        {examQuestions.length} questions · {EXAM_DURATION_MINUTES} minutes · auto-submits when the timer expires.
        No correctness feedback until you finish.
      </p>
    </header>

    {examQuestions.length === 0 ? (
      <div class="card" style="padding: 28px;">
        No quiz content available yet. Add some quiz YAML files under <code>src/generated/quiz/</code>.
      </div>
    ) : (
      <ExamRunner
        client:only="react"
        questions={examQuestions}
        examSlug={EXAM_SLUG}
        durationMs={EXAM_DURATION_MS}
      />
    )}
  </div>
  {/* No site footer on the focused, timed exam surface: the client:only ExamRunner
      renders empty on SSR, so a footer below it gets pushed down on hydration → CLS. */}
  <Fragment slot="footer" />
</BaseLayout>

<style>
  .exam-page {
    max-width: 880px;
    margin: 0 auto;
    padding: 36px 24px 80px;
  }
  .exam-page__head {
    margin-bottom: 28px;
  }
  .exam-page__head h1 {
    font-family: var(--serif);
    font-size: 48px;
    font-weight: 400;
    letter-spacing: -0.03em;
    margin: 8px 0 12px;
    color: var(--ink);
    line-height: 1.05;
  }
  .lead {
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.5;
    margin: 0;
    max-width: 640px;
  }
</style>
