---
interface Props {
  id: string;
  wordTarget?: number;
}

const { id, wordTarget } = Astro.props;
---

<div class="mdx-feynman" data-feynman-id={id} data-word-target={wordTarget}>
  <p class="eyebrow mdx-feynman__label">
    feynman prompt · {id}{wordTarget ? ` · ~${wordTarget} words` : ''}
  </p>
  <div class="mdx-feynman__body">
    <slot />
  </div>
</div>

<style>
  .mdx-feynman {
    margin: 20px 0;
    padding: 16px 18px;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--paper);
  }
  .mdx-feynman__label { margin: 0 0 8px; }
  .mdx-feynman__body { font-size: 15px; color: var(--ink); }
</style>
