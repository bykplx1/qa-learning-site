---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortCurriculum, groupByCluster, clusterDisplay } from '../../lib/curriculum/order';
import type { CurriculumEntry } from '../../lib/curriculum/order';
import type { CurriculumCluster } from '../../lib/curriculum/schema';

const allTopics = await getCollection('curriculum');
const sorted = sortCurriculum(allTopics);
const groups = groupByCluster(allTopics);

const clusterRows = Array.from(groups.entries())
  .filter(([, topics]) => topics.length > 0)
  .map(([cluster, topics]) => ({
    cluster,
    topics,
  }));

const totalTopics = sorted.length;
const totalMinutes = sorted.reduce((s, t) => s + t.data.estimatedEncodingMinutes, 0);

function layerIndicator(layer: CurriculumEntry['data']['layer']): string {
  return layer === 'facts' ? 'b' : layer === 'patterns' ? 'i' : 'a';
}

const siteOrigin = (Astro.site ?? Astro.url).origin;

const lessonsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'QA Learning Curriculum',
  description: `All ${totalTopics} QA topics grouped by track.`,
  url: siteOrigin + '/lessons',
  numberOfItems: totalTopics,
  itemListElement: sorted.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: t.data.title,
    url: `${siteOrigin}/lessons/${t.data.cluster}/${t.data.slug}`,
  })),
};
---

<BaseLayout
  title="Lessons — QA Learning"
  description={`All ${totalTopics} QA topics grouped by track. ${totalMinutes} minutes of reading across ${clusterRows.length} curriculum tracks.`}
  jsonLd={lessonsJsonLd}
>
  <section class="section">
    <div class="section__head">
      <div>
        <span class="eyebrow">curriculum · {clusterRows.length} tracks</span>
        <h1>Lessons</h1>
      </div>
      <p>{totalTopics} topics · {totalMinutes}m total read time</p>
    </div>

    {clusterRows.map(({ cluster, topics }) => (
      <div style="margin-bottom: 40px;">
        <div class="section__head" style="margin-bottom: 16px;">
          <div>
            <span class="eyebrow">{cluster} · {topics.length} topic{topics.length === 1 ? '' : 's'}</span>
            <h2 style="font-size: 26px;">{clusterDisplay(cluster as CurriculumCluster)}</h2>
          </div>
        </div>
        <div class="lessons-list">
          {topics.map((t, i) => {
            const diff = layerIndicator(t.data.layer);
            return (
              <a class="lrow" href={`/lessons/${t.data.cluster}/${t.data.slug}`}>
                <span class="lrow__idx">{i + 1}</span>
                <div class="lrow__title">
                  {t.data.title}
                  <small>{t.data.tags.slice(0, 3).join(' · ')}</small>
                </div>
                <span class="lrow__min">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                  {t.data.estimatedEncodingMinutes}m
                </span>
                <span class={`lrow__diff diff-${diff}`} title={t.data.layer}></span>
              </a>
            );
          })}
        </div>
      </div>
    ))}
  </section>

  <footer class="site-footer" slot="footer" role="contentinfo" aria-label="Site footer">
    <span>© {new Date().getFullYear()} · MIT · QA Learning</span>
    <nav aria-label="Footer">
      <a href="/lessons">Lessons</a>
      <a href="/projects">Build</a>
      <a href="/privacy">Privacy</a>
    </nav>
    <span>{totalTopics} topics across {clusterRows.length} tracks</span>
  </footer>
</BaseLayout>
