---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;

// `next` is where we send the user after a successful sign-in. Only accept a
// local path (single leading slash, no protocol-relative "//host") to prevent
// open-redirects; anything else falls back to the home page.
const rawNext = Astro.url.searchParams.get('next') ?? '/';
const next = /^\/(?!\/)[\w\-/?.=&#%+]*$/.test(rawNext) ? rawNext : '/';
---

<BaseLayout title="Sign in — QA Learning" description="Choose how you want to sign in to QA Learning.">
  <main class="login-page">
    <div class="login-card">
      <span class="eyebrow">authentication</span>
      <h1 class="login-card__heading">Sign in to <em>QA&nbsp;Learning</em></h1>
      <p class="login-card__sub">
        Track your progress, quiz scores, projects, and streaks — all kept against your account.
      </p>
      <div class="login-card__providers" role="group" aria-label="Sign-in options">
        <button
          type="button"
          data-provider="github"
          data-callback={next}
          class="btn btn--primary btn--lg login-card__provider-btn"
        >
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844a9.59 9.59 0 012.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.021C22 6.484 17.522 2 12 2z"/>
          </svg>
          Continue with GitHub
        </button>
        <button
          type="button"
          data-provider="google"
          data-callback={next}
          class="btn btn--ghost btn--lg login-card__provider-btn"
        >
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        </button>
      </div>
      <p class="login-card__note">
        GitHub and Google accounts with the same verified email are automatically linked.
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .login-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 60px);
    padding: 40px 20px;
  }

  .login-card {
    width: 100%;
    max-width: 400px;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 14px;
    padding: 40px 36px;
    text-align: center;
  }

  .login-card__heading {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 32px;
    letter-spacing: -0.03em;
    margin: 8px 0 12px;
    color: var(--ink);
    line-height: 1.15;
  }

  .login-card__heading em {
    font-style: italic;
    color: var(--accent);
  }

  .login-card__sub {
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.55;
    margin: 0 0 28px;
  }

  .login-card__providers {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .login-card__provider-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
  }

  .login-card__note {
    font-size: 12px;
    color: var(--ink-3);
    font-family: var(--mono);
    margin: 20px 0 0;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .login-card {
      padding: 28px 20px;
    }
    .login-card__heading {
      font-size: 26px;
    }
  }
</style>

<script>
  // POST to better-auth's social sign-in endpoint and follow the returned redirect.
  // Direct GET links to /api/auth/sign-in/<provider> do not exist in better-auth —
  // the only supported path is POST /api/auth/sign-in/social with JSON body.
  document.querySelectorAll<HTMLButtonElement>('button[data-provider]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const provider = btn.dataset.provider as string;
      const callbackURL = btn.dataset.callback || '/';
      btn.disabled = true;
      try {
        const res = await fetch('/api/auth/sign-in/social', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ provider, callbackURL }),
        });
        if (!res.ok) {
          btn.disabled = false;
          return;
        }
        const data = await res.json() as { url?: string; redirect?: boolean };
        if (data.url) {
          window.location.href = data.url;
        } else {
          btn.disabled = false;
        }
      } catch {
        btn.disabled = false;
      }
    });
  });
</script>
