---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  appendHeadings?: Heading[];
}

const { headings, appendHeadings = [] } = Astro.props;
const tocHeadings = [
  ...headings.filter((h) => h.depth === 2 || h.depth === 3),
  ...appendHeadings,
];
---

{tocHeadings.length > 0 && (
  <nav aria-label="Table of contents">
    <p class="eyebrow" style="margin-bottom: 14px;">on this page</p>
    <ul class="toc-list">
      {tocHeadings.map((h) => (
        <li class={h.depth === 3 ? 'toc-l3' : ''}>
          <a
            href={`#${h.slug}`}
            class="toc-link"
            data-heading={h.slug}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style is:global>
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
    font-size: 12px;
    border-left: 1px solid var(--rule);
  }
  .toc-l3 { padding-left: 12px; }
  .toc-link {
    display: block;
    padding: 2px 0 2px 12px;
    margin-left: -1px;
    border-left: 2px solid transparent;
    color: var(--ink-3);
    text-decoration: none;
    line-height: 1.5;
    transition: color 120ms ease;
  }
  .toc-link:hover { color: var(--ink-2); }
  .toc-link.is-active {
    color: var(--ink);
    border-left-color: var(--accent);
    font-weight: 500;
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  if (links.length > 0) {
    const headingIds = Array.from(links).map((l) => l.dataset.heading!);
    const headingEls = headingIds
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    let activeId: string | null = null;

    function setActive(id: string | null) {
      if (id === activeId) return;
      activeId = id;
      links.forEach((l) => {
        l.classList.toggle('is-active', l.dataset.heading === id);
      });
    }

    const visibleSet = new Set<string>();

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            visibleSet.add(entry.target.id);
          } else {
            visibleSet.delete(entry.target.id);
          }
        }
        // Prefer the first heading currently in the active band; when none are
        // (e.g. on initial load before any scroll, or at the very top), fall
        // back to the first heading so the TOC always reflects a position.
        const first = headingIds.find((id) => visibleSet.has(id)) ?? headingIds[0];
        if (first) setActive(first);
      },
      { rootMargin: '-80px 0px -50% 0px', threshold: 0 }
    );

    headingEls.forEach((el) => observer.observe(el));
  }
</script>
