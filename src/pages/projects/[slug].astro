---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SelfAttestChecklist from '../../components/projects/SelfAttestChecklist';
import SubmitProjectForm from '../../components/projects/SubmitProjectForm';
import RubricPanel from '../../components/projects/RubricPanel';
import ConceptGate from '../../components/projects/ConceptGate';
import { TIER_LABELS } from '../../lib/projects/schema';
import { rubrics } from '../../lib/projects/rubric';
import { getSession } from '../../lib/auth';
import { getSubmission } from '../../db/queries';
import { getConceptStabilities, buildGateStatus } from '../../lib/projects/concept-gate';

export const prerender = false;

const all = await getCollection('projects');
const slug = Astro.params.slug;
const project = all.find((p) => p.data.slug === slug);
if (!project) {
  return new Response('Not Found', { status: 404 });
}

const { Content } = await render(project);
const { title, tier, estimate, acceptanceCriteria, rubric: rubricId } = project.data;
const rubricDef = rubricId ? rubrics[rubricId as keyof typeof rubrics] ?? null : null;

const session = await getSession(Astro.request.headers);
const userId = session?.user?.id ?? null;
const existing = userId && process.env.E2E_OAUTH_MOCK !== '1'
  ? await getSubmission(userId, project.data.slug)
  : null;
const existingProp = existing
  ? {
      repoUrl: existing.repoUrl,
      reflection: existing.reflection,
      isPublic: existing.isPublic,
      submittedAt: existing.submittedAt.toISOString(),
    }
  : null;

// Concept gate: load stability data server-side; pass plain props to React island.
const requiredConcepts: string[] = project.data.requiredConcepts ?? [];

// Resolve gate status: skip when no requiredConcepts or no user.
// E2E mock mode: build deterministic gate from env vars to avoid DB hit.
const gate = await (async () => {
  if (requiredConcepts.length === 0 || !userId) return null;

  if (process.env.E2E_OAUTH_MOCK === '1') {
    const forceBelow = process.env.E2E_CONCEPT_GATE_BELOW === '1';
    const dueCards = forceBelow ? parseInt(process.env.E2E_CONCEPT_GATE_DUE_CARDS ?? '3', 10) : 0;
    const concepts = requiredConcepts.map((c, i) => ({
      concept: c,
      cluster: c,
      stability: forceBelow && i === 0 ? 0.2 : 1.5,
      totalCards: 3,
      dueCards: forceBelow && i === 0 ? dueCards : 0,
      belowThreshold: forceBelow && i === 0,
    }));
    const failing = concepts.filter((c) => c.belowThreshold);
    return {
      allMet: failing.length === 0,
      concepts,
      primaryCluster: failing[0]?.cluster ?? null,
      dueCardCount: failing.reduce((s, c) => s + c.dueCards, 0),
      estimatedMinutes: Math.ceil((failing.reduce((s, c) => s + c.dueCards, 0) * 45) / 60),
    };
  }

  return buildGateStatus(await getConceptStabilities(userId, requiredConcepts));
})();

function splitTitleAccent(t: string): { head: string; tail: string } {
  const idx = t.lastIndexOf(' ');
  if (idx <= 0 || t.split(' ').length < 2) return { head: '', tail: t };
  return { head: t.slice(0, idx), tail: t.slice(idx + 1) };
}
const { head, tail } = splitTitleAccent(title);

const canonicalUrl = new URL(`/projects/${project.data.slug}`, Astro.site).href;
---

<BaseLayout
  title={`${title} — Build — QA Learning`}
  description={`${TIER_LABELS[tier]} project · ${estimate}. ${acceptanceCriteria.length} acceptance criteria.`}
  canonicalUrl={canonicalUrl}
  ogType="article"
>
  <main class="brief">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">QA Learning</a>
      <span class="sep">/</span>
      <a href="/projects">Build</a>
      <span class="sep">/</span>
      <span class="crumb-current">{title}</span>
    </nav>

    {gate && (
      <ConceptGate
        client:load
        projectSlug={project.data.slug}
        gate={gate}
      />
    )}

    <header style="margin-bottom: 32px;">
      <h1 class="brief__title">
        {head ? (
          <>
            {head}{' '}
            <em>{tail}</em>
          </>
        ) : (
          tail
        )}
      </h1>
      <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px;">
        <span class="pill pill--accent">{TIER_LABELS[tier]}</span>
        <span class="pill">{estimate}</span>
        <span class="pill">{acceptanceCriteria.length} acceptance criteria</span>
      </div>
    </header>

    <article class="prose">
      <Content />
    </article>

    <section style="margin-top: 40px;" aria-label="Acceptance criteria">
      <span class="eyebrow">acceptance criteria</span>
      <ol style="list-style: none; padding: 0; margin: 14px 0 0; display: grid; gap: 8px;">
        {acceptanceCriteria.map((c, i) => (
          <li
            style="display: grid; grid-template-columns: 32px 1fr; gap: 14px; padding: 12px 0; border-top: 1px solid var(--rule);"
          >
            <span style="font-family: var(--mono); font-size: 11px; color: var(--ink-3); padding-top: 3px; letter-spacing: 0.04em;">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div style="font-size: 14px; color: var(--ink-2); line-height: 1.55;">{c}</div>
          </li>
        ))}
      </ol>
    </section>

    {rubricDef && (
      <RubricPanel
        client:load
        rubric={rubricDef}
      />
    )}

    <SelfAttestChecklist
      client:load
      projectSlug={project.data.slug}
      criteria={acceptanceCriteria}
    />

    {userId ? (
      <SubmitProjectForm
        client:load
        projectSlug={project.data.slug}
        existing={existingProp}
        rubric={rubricDef}
      />
    ) : (
      <section class="card" style="margin-top: 32px;">
        <div class="eyebrow" style="margin-bottom: 8px;">submit your build</div>
        <p style="font-size: 14px; color: var(--ink-2); margin: 0;">
          <a href="/api/auth/sign-in/github" style="color: var(--accent); text-decoration: underline;">
            Sign in
          </a>{' '}
          to submit your repo URL and a short reflection on what you learned.
        </p>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .brief {
    padding: 44px 56px;
    max-width: 800px;
    margin: 0 auto;
  }
  @media (max-width: 768px) { .brief { padding: 28px 20px; } }

  .brief__title {
    font-family: var(--serif);
    font-size: 52px;
    font-weight: 400;
    letter-spacing: -0.03em;
    margin: 0;
    line-height: 1.05;
    color: var(--ink);
  }
  .brief__title em { font-style: italic; color: var(--accent); font-weight: 400; }
  @media (max-width: 768px) { .brief__title { font-size: 38px; } }
</style>
