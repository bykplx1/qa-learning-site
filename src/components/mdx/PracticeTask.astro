---
import PracticeTaskIsland from './PracticeTaskIsland';

interface Props {
  id: string;
  rubric: string;
}

const { id, rubric } = Astro.props;
---

<PracticeTaskIsland client:load id={id} rubricId={rubric}>
  <slot />
</PracticeTaskIsland>

<style>
  :global(.mdx-task) {
    margin: 20px 0;
    padding: 18px 20px;
    border: 1px solid var(--rule);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
    background: var(--paper-2);
  }
  :global(.mdx-task__label) { margin: 0 0 8px; }
  :global(.mdx-task__body) { font-size: 15px; color: var(--ink); }
</style>
