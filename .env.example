# Postgres connection (Neon in prod, local/CI in dev). Drizzle + better-auth read this.
DATABASE_URL=

# Random 32+ byte secret for session signing. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public origin of the site, no trailing slash. e.g. http://localhost:4321 or https://qa-learning-site.vercel.app
BETTER_AUTH_URL=

# GitHub OAuth app credentials. Create at https://github.com/settings/developers
# Authorization callback URL must be: $BETTER_AUTH_URL/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth client credentials. Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: $BETTER_AUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Test accounts (dev / Vercel preview ONLY) ────────────────────────────────
# Lets you log in as a fixed test persona at /dev/login to walk auth-gated UX
# without OAuth (which can't run on preview URLs). HARD-DISABLED in production:
# the code returns 404 whenever VERCEL_ENV=production, regardless of these vars.
#
# Set ENABLE_TEST_LOGIN=1 to turn the feature on (local and/or Vercel *Preview*
# environment), and TEST_LOGIN_SECRET to a random string the picker requires.
# Visit /dev/login?key=<TEST_LOGIN_SECRET>.  Leave both blank to keep it off.
ENABLE_TEST_LOGIN=
TEST_LOGIN_SECRET=

# ── Deployment (Vercel CLI / CI only — NOT app runtime) ──────────────────────
# Used by `vercel` / `vercel deploy` locally and in CI. Production runtime
# secrets (DATABASE_URL, BETTER_AUTH_SECRET, OAuth creds) are set in the Vercel
# project dashboard, never in this repo. ORG/PROJECT ids also live in
# .vercel/project.json after `vercel link`. Generate a token at
# https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
