---
// `id` is the stable key. Renaming a prompt creates a new card and orphans history — see lint rule (P2).
interface Props {
  id: string;
  cluster?: string;
}

const { id, cluster } = Astro.props;
---

<div
  class="mdx-prompt"
  data-prompt-id={id}
  data-cluster={cluster ?? undefined}
>
  <p class="eyebrow mdx-prompt__label">retrieval prompt · {id}</p>
  <div class="mdx-prompt__body">
    <slot />
  </div>
  <p class="mdx-prompt__hint">Recall from memory first, then check yourself against the lesson above.</p>
</div>

<style>
  .mdx-prompt {
    margin: 16px 0;
    padding: 14px 16px;
    border-left: 3px solid var(--accent);
    background: var(--paper-2);
    border-radius: 0 8px 8px 0;
  }
  .mdx-prompt__label { margin: 0 0 6px; }
  .mdx-prompt__body { font-size: 15px; color: var(--ink); }
  .mdx-prompt__hint {
    margin: 10px 0 0;
    font-size: 13px;
    font-family: var(--mono);
    color: var(--ink-3);
  }
</style>
