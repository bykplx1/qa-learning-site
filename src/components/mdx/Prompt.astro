---
interface Props {
  id: string;
  requiresDiagram?: boolean;
}

const { id, requiresDiagram } = Astro.props;
---

<div class="mdx-prompt" data-prompt-id={id} data-requires-diagram={requiresDiagram ? 'true' : undefined}>
  <p class="eyebrow mdx-prompt__label">retrieval prompt · {id}</p>
  <div class="mdx-prompt__body">
    <slot />
  </div>
</div>

<style>
  .mdx-prompt {
    margin: 16px 0;
    padding: 14px 16px;
    border-left: 3px solid var(--accent);
    background: var(--paper-2);
    border-radius: 0 8px 8px 0;
  }
  .mdx-prompt__label { margin: 0 0 6px; }
  .mdx-prompt__body { font-size: 15px; color: var(--ink); }
</style>
