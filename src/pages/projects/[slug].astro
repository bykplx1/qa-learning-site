---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SelfAttestChecklist from '../../components/projects/SelfAttestChecklist';
import SubmitProjectForm from '../../components/projects/SubmitProjectForm';
import { TIER_LABELS, type ProjectTier } from '../../lib/projects/schema';
import { auth } from '../../lib/auth';
import { getSubmission } from '../../db/queries';

export const prerender = false;

const all = await getCollection('projects');
const slug = Astro.params.slug;
const project = all.find((p) => p.data.slug === slug);
if (!project) {
  return new Response('Not Found', { status: 404 });
}

const { Content } = await render(project);
const { title, tier, estimate, acceptanceCriteria } = project.data;

const session = await auth.api.getSession({ headers: Astro.request.headers });
const userId = session?.user?.id ?? null;
const existing = userId ? await getSubmission(userId, project.data.slug) : null;
const existingProp = existing
  ? {
      repoUrl: existing.repoUrl,
      reflection: existing.reflection,
      isPublic: existing.isPublic,
      submittedAt: existing.submittedAt.toISOString(),
    }
  : null;

const tierBadge: Record<ProjectTier, string> = {
  starter: 'bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200',
  mid: 'bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200',
  capstone: 'bg-red-100 dark:bg-red-900 text-red-800 dark:text-red-200',
};

const canonicalUrl = new URL(`/projects/${project.data.slug}`, Astro.site).href;
---

<BaseLayout
  title={`${title} — Build — QA Learning`}
  description={`${TIER_LABELS[tier]} project · ${estimate}. ${acceptanceCriteria.length} acceptance criteria.`}
  canonicalUrl={canonicalUrl}
  ogType="article"
>
  <main class="px-6 py-10 max-w-3xl mx-auto">
    <nav class="text-sm text-gray-500 dark:text-gray-400 mb-6 flex items-center gap-1.5">
      <a href="/" class="hover:text-gray-900 dark:hover:text-gray-100">Home</a>
      <span>›</span>
      <a href="/projects" class="hover:text-gray-900 dark:hover:text-gray-100">Build</a>
      <span>›</span>
      <span class="text-gray-900 dark:text-gray-100">{title}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-3">{title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
        <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${tierBadge[tier]}`}>
          {TIER_LABELS[tier]}
        </span>
        <span>·</span>
        <span>{estimate}</span>
      </div>
    </header>

    <article class="prose dark:prose-invert max-w-none">
      <Content />
    </article>

    <section class="mt-10" aria-label="Acceptance criteria">
      <h2 class="text-xl font-semibold mb-3">Acceptance criteria</h2>
      <ul class="list-disc pl-6 space-y-2 text-gray-800 dark:text-gray-200">
        {acceptanceCriteria.map((c) => (
          <li>{c}</li>
        ))}
      </ul>
    </section>

    <SelfAttestChecklist
      client:load
      projectSlug={project.data.slug}
      criteria={acceptanceCriteria}
    />

    {userId ? (
      <SubmitProjectForm
        client:load
        projectSlug={project.data.slug}
        existing={existingProp}
      />
    ) : (
      <section class="mt-8 p-5 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
        <p class="text-sm text-gray-700 dark:text-gray-300 m-0">
          <a href="/api/auth/sign-in/github" class="underline">Sign in</a> to submit your build.
        </p>
      </section>
    )}
  </main>
</BaseLayout>
