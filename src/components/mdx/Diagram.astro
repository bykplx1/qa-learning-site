---
interface Props {
  /** Mermaid source — no longer supported; pass inline SVG via slot instead. */
  src?: never;
  caption?: string;
  /** Depth-gate prop — accepted here, lint enforces correct usage (#144). */
  skip?: 'atomic-fact';
}

const { caption, skip } = Astro.props;
---

{skip === 'atomic-fact' ? (
  <div class="mdx-diagram mdx-diagram--skipped" data-skip={skip} aria-hidden="true"></div>
) : (
  <figure class="mdx-diagram mdx-diagram--inline-svg">
    <div class="mdx-diagram__body">
      <slot />
    </div>
    {caption && <figcaption class="mdx-diagram__caption">{caption}</figcaption>}
  </figure>
)}

<style>
  .mdx-diagram {
    margin: 24px 0;
    padding: 16px;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--paper-2);
    overflow: hidden;
  }
  .mdx-diagram--skipped { display: none; }

  .mdx-diagram__body {
    overflow-x: auto;
  }

  :global(.mdx-diagram__svg-wrap) {
    width: 100%;
    overflow-x: auto;
  }
  :global(.mdx-diagram__svg-wrap svg) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .mdx-diagram__caption,
  :global(.mdx-diagram__caption) {
    margin-top: 8px;
    font-size: 13px;
    color: var(--ink-3);
    font-family: var(--mono);
    display: block;
  }
</style>
