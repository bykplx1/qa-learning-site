---
import type { CtaOption } from '../../lib/lessons/end-cta';

interface Props {
  options: CtaOption[];
  cluster: string;
  slug: string;
  title: string;
}

const { options, cluster, slug, title } = Astro.props;

const editUrl = `https://github.com/bykplx1/qa-learning-site/edit/main/content/curriculum/${cluster}/${slug}.mdx`;
const issueTitle = encodeURIComponent(`Content error: ${slug}`);
const issueBody = encodeURIComponent(
  `**Lesson:** [${title}](https://qa-learning-site.vercel.app/lessons/${cluster}/${slug}/)\n\n**Describe the error:**\n\n<!-- What is wrong or unclear? -->\n`
);
const reportUrl = `https://github.com/bykplx1/qa-learning-site/issues/new?title=${issueTitle}&body=${issueBody}&labels=content`;

const iconByKind: Record<string, string> = {
  review: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>`,
  explain: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  project: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`,
};
---

{options.length > 0 && (
  <nav
    class="end-cta"
    aria-label="Next steps"
    data-testid="end-of-lesson-cta"
  >
    <p class="end-cta__heading eyebrow">What to do next</p>
    <ul class="end-cta__list" role="list">
      {options.map((opt, i) => (
        <li>
          <a
            href={opt.href}
            class={`end-cta__card${i === 0 ? ' end-cta__card--primary' : ''}`}
            data-testid={`end-cta-${opt.kind}`}
          >
            <span class="end-cta__icon" set:html={iconByKind[opt.kind]} />
            <span class="end-cta__body">
              <span class="end-cta__label">{opt.label}</span>
              <span class="end-cta__desc">{opt.description}</span>
            </span>
            <span class="end-cta__arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<div class="correction-links">
  <a
    href={editUrl}
    class="correction-link"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Edit this lesson on GitHub (opens in new tab)"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
    Edit on GitHub
  </a>
  <span class="correction-sep" aria-hidden="true">·</span>
  <a
    href={reportUrl}
    class="correction-link"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Report an error in this lesson on GitHub (opens in new tab)"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    Report an error
  </a>
</div>

<style>
  .end-cta {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--rule);
  }

  .end-cta__heading {
    margin: 0 0 16px;
  }

  .end-cta__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .end-cta__card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border: 1px solid var(--rule);
    border-radius: 10px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 150ms ease, background 150ms ease;
  }

  .end-cta__card:hover {
    border-color: var(--ink-3);
    background: var(--paper-2);
  }

  .end-cta__card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .end-cta__card--primary {
    border-color: var(--accent);
    background: var(--paper-2);
  }

  .end-cta__card--primary:hover {
    background: var(--paper-3, var(--paper-2));
  }

  .end-cta__icon {
    flex-shrink: 0;
    color: var(--accent);
    display: flex;
    align-items: center;
  }

  .end-cta__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .end-cta__label {
    font-size: 14px;
    font-weight: 500;
  }

  .end-cta__desc {
    font-size: 12px;
    color: var(--ink-2);
  }

  .end-cta__arrow {
    flex-shrink: 0;
    color: var(--ink-3);
    font-size: 14px;
  }

  .correction-links {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    font-size: 12px;
    color: var(--ink-3);
  }

  .correction-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--ink-3);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .correction-link:hover {
    color: var(--ink-2);
    text-decoration: underline;
  }

  .correction-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .correction-sep {
    color: var(--ink-3);
  }
</style>
