---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubmissionsList from '../components/profile/SubmissionsList';
import { auth } from '../lib/auth';
import { getCompletedLessonCount, getQuizAttemptCount, listSubmissions } from '../db/queries';

export const prerender = false;

const session = await auth.api.getSession({ headers: Astro.request.headers });
const user = session?.user ?? null;
const completedCount = user?.id ? await getCompletedLessonCount(user.id) : 0;
const attemptCount = user?.id ? await getQuizAttemptCount(user.id) : 0;
const submissions = user?.id ? await listSubmissions(user.id) : [];
const submissionsProp = submissions.map((s) => ({
  projectSlug: s.projectSlug,
  repoUrl: s.repoUrl,
  reflection: s.reflection,
  isPublic: s.isPublic,
  submittedAt: s.submittedAt.toISOString(),
}));
---

<BaseLayout title="Profile — QA Learning">
  <main class="px-6 py-12 max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">Profile</h1>
    {user ? (
      <div class="space-y-4">
        <p class="text-gray-700 dark:text-gray-300">
          Signed in as <span class="font-medium">{user.name ?? user.email}</span>
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-800">
            <div class="text-sm text-gray-500 dark:text-gray-400">Lessons completed</div>
            <div class="text-3xl font-semibold mt-1" data-testid="completed-count">{completedCount}</div>
          </div>
          <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-800">
            <div class="text-sm text-gray-500 dark:text-gray-400">Quiz attempts</div>
            <div class="text-3xl font-semibold mt-1" data-testid="attempt-count">{attemptCount}</div>
          </div>
        </div>

        <section class="mt-8" aria-label="Project submissions" data-testid="submissions-section">
          <h2 class="text-xl font-semibold mb-3">Project submissions</h2>
          <SubmissionsList client:load submissions={submissionsProp} />
        </section>
      </div>
    ) : (
      <p class="text-gray-700 dark:text-gray-300">Sign in to see your progress.</p>
    )}
  </main>
</BaseLayout>
