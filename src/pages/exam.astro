---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CERTIFICATES } from '../lib/exam/certificates';
import { buildCertExamPool } from '../lib/exam/pool';

export const prerender = true;

// Only surface certificates that actually have a populated question bank, so the
// selector never links to an empty exam.
const cards = CERTIFICATES.map((cert) => ({
  cert,
  available: buildCertExamPool(cert.id).length > 0,
})).filter((c) => c.available);
---

<BaseLayout
  title="Mock exams — QA Learning"
  description="Choose an ISTQB certification and sit a timed mock exam that matches the real exam's question count, time limit and 65% pass mark."
>
  <div class="exam-select">
    <header class="exam-select__head">
      <span class="eyebrow">mock exams</span>
      <h1>Choose a certification</h1>
      <p class="lead">
        Each mock exam mirrors the real ISTQB sitting — its question count, time limit and 65% pass
        mark. Questions are timed, navigable, and graded only when you submit. Pick the certificate
        you want to practise for.
      </p>
    </header>

    <ul class="cert-grid" role="list">
      {cards.map(({ cert }) => (
        <li class="cert-card">
          <a href={`/exam/${cert.id}`} class="cert-card__link" data-testid={`cert-card-${cert.id}`}>
            <span class="cert-card__code">{cert.code}</span>
            <h2 class="cert-card__name">{cert.name}</h2>
            <p class="cert-card__desc">{cert.description}</p>
            <dl class="cert-card__meta">
              <div><dt>Questions</dt><dd>{cert.questionCount}</dd></div>
              <div><dt>Time</dt><dd>{cert.durationMinutes} min</dd></div>
              <div><dt>Pass</dt><dd>{Math.round(cert.passThreshold * 100)}%</dd></div>
            </dl>
            <span class="cert-card__cta">Start mock exam →</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .exam-select {
    max-width: 980px;
    margin: 0 auto;
    padding: 36px 24px 80px;
  }
  .exam-select__head {
    margin-bottom: 32px;
    max-width: 720px;
  }
  .exam-select__head h1 {
    font-family: var(--serif);
    font-size: 48px;
    font-weight: 400;
    letter-spacing: -0.03em;
    margin: 8px 0 12px;
    color: var(--ink);
    line-height: 1.05;
  }
  .lead {
    color: var(--ink-2);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }
  .cert-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .cert-card {
    display: flex;
  }
  .cert-card__link {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
    padding: 24px;
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: var(--paper);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .cert-card__link:hover,
  .cert-card__link:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 16px 40px -24px rgba(0, 0, 0, 0.35);
    transform: translateY(-2px);
  }
  .cert-card__code {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-strong);
  }
  .cert-card__name {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0;
    color: var(--ink);
  }
  .cert-card__desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    flex: 1;
  }
  .cert-card__meta {
    display: flex;
    gap: 18px;
    margin: 6px 0 0;
    padding: 12px 0 0;
    border-top: 1px solid var(--rule);
  }
  .cert-card__meta div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cert-card__meta dt {
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-family: var(--sans);
  }
  .cert-card__meta dd {
    margin: 0;
    font-family: var(--mono);
    font-size: 16px;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
  .cert-card__cta {
    margin-top: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--accent-strong);
    font-family: var(--sans);
  }
</style>
