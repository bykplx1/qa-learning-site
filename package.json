{
  "name": "qa-learning-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint:curriculum": "tsx scripts/lint-curriculum.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "ts-fsrs": "5.3.3",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.2.1",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@fontsource/inter": "^5.2.8",
    "@playwright/test": "1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "pagefind": "^1.5.2",
    "satori": "^0.26.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
