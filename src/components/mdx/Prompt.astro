---
// `id` is the stable key. Renaming a prompt creates a new card and orphans history — see lint rule (P2).
interface Props {
  id: string;
  question: string;
  answer: string;
  cluster?: string;
}

const { id, question, answer, cluster } = Astro.props;
---

<div
  class="mdx-prompt"
  data-prompt-id={id}
  data-cluster={cluster ?? undefined}
>
  <p class="eyebrow mdx-prompt__label">retrieval prompt · {id}</p>
  <div class="mdx-prompt__body">
    <slot />
    <p class="mdx-prompt__question">{question}</p>
  </div>
  <details class="mdx-prompt__reveal">
    <summary>Reveal answer</summary>
    <div class="mdx-prompt__answer">{answer}</div>
  </details>
</div>

<style>
  .mdx-prompt {
    margin: 16px 0;
    padding: 14px 16px;
    border-left: 3px solid var(--accent);
    background: var(--paper-2);
    border-radius: 0 8px 8px 0;
  }
  .mdx-prompt__label { margin: 0 0 6px; }
  .mdx-prompt__body { font-size: 15px; color: var(--ink); }
  .mdx-prompt__question { font-weight: 600; margin: 8px 0 0; }
  .mdx-prompt__reveal {
    margin-top: 10px;
    font-size: 14px;
  }
  .mdx-prompt__reveal summary {
    cursor: pointer;
    /* --accent (4.07:1 on --paper-2) fails WCAG 1.4.3 at 14px; --accent-strong clears 4.5:1 */
    color: var(--accent-strong);
    user-select: none;
  }
  .mdx-prompt__answer {
    margin-top: 8px;
    padding: 10px 12px;
    background: var(--paper-3, var(--paper-2));
    border-radius: 6px;
    color: var(--ink);
  }
</style>
