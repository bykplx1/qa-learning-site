---
import type { ActivityItem } from '../../lib/activity/activity';

interface Props {
  items: ActivityItem[];
}

const { items } = Astro.props;

const KIND_LABEL: Record<ActivityItem['kind'], string> = {
  lesson: 'lesson',
  quiz: 'quiz',
  project: 'project',
};

function relativeTime(d: Date): string {
  const diffMs = Date.now() - d.getTime();
  const m = Math.round(diffMs / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.round(m / 60);
  if (h < 24) return `${h}h ago`;
  const days = Math.round(h / 24);
  if (days < 30) return `${days}d ago`;
  const months = Math.round(days / 30);
  if (months < 12) return `${months}mo ago`;
  return `${Math.round(months / 12)}y ago`;
}
---

<div class="card" data-testid="recent-activity-section" aria-label="Recent activity">
  <span class="eyebrow">recent activity</span>
  {items.length === 0 ? (
    <p
      data-testid="recent-activity-empty"
      style="color: var(--ink-3); font-size: 14px; margin-top: 12px;"
    >
      Nothing here yet — finish a lesson, take a quiz, or ship a project to see it land in the feed.
    </p>
  ) : (
    <ul class="recent-activity" data-testid="recent-activity-list">
      {items.map((item) => {
        const iso = item.timestamp.toISOString();
        const human = item.timestamp.toLocaleString(undefined, {
          year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit',
        });
        return (
          <li class="recent-activity__row" data-testid={`activity-row-${item.kind}-${item.slug}`}>
            <span class={`pill pill--${item.kind}`} data-testid={`activity-kind-${item.kind}`}>
              {KIND_LABEL[item.kind]}
            </span>
            <a href={item.href} class="recent-activity__title">{item.title}</a>
            {item.kind === 'quiz' && item.score != null && item.total != null && (
              <span class="recent-activity__meta">
                {item.score}/{item.total}
                {item.mode && item.mode !== 'practice' ? ` · ${item.mode}` : ''}
              </span>
            )}
            <time datetime={iso} title={human} class="recent-activity__time">
              {relativeTime(item.timestamp)}
            </time>
          </li>
        );
      })}
    </ul>
  )}
</div>

<style>
  .recent-activity {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .recent-activity__row {
    display: grid;
    grid-template-columns: 70px 1fr auto auto;
    align-items: baseline;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid var(--rule);
    font-size: 13px;
  }
  .recent-activity__row:last-child { border-bottom: none; }
  .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 2px 8px;
    border-radius: 99px;
    color: var(--ink-2);
    background: var(--paper-3);
  }
  .pill--quiz { background: oklch(94% 0.05 35); color: var(--accent-strong); }
  .pill--project { background: oklch(93% 0.06 220); color: oklch(38% 0.14 220); }
  .recent-activity__title {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .recent-activity__title:hover { border-bottom-color: var(--ink-3); }
  .recent-activity__meta {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
  }
  .recent-activity__time {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .recent-activity__row {
      grid-template-columns: 60px 1fr;
    }
    .recent-activity__meta, .recent-activity__time {
      grid-column: 2;
    }
  }
</style>
