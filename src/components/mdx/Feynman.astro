---
import FeynmanEditor from '../explain/FeynmanEditor';

interface Props {
  id: string;
  wordTarget?: number;
}

const { id, wordTarget = 150 } = Astro.props;
const showGapPrompt = import.meta.env.FEATURE_AI_GAP_PROMPT === '1';
---

<div class="mdx-feynman" data-feynman-id={id}>
  <p class="eyebrow mdx-feynman__label">
    feynman prompt · {id} · ~{wordTarget} words
  </p>
  <div class="mdx-feynman__prompt">
    <slot />
  </div>
  <div class="mdx-feynman__editor">
    <FeynmanEditor client:load conceptSlug={id} wordTarget={wordTarget} showGapPrompt={showGapPrompt} />
  </div>
</div>

<style>
  .mdx-feynman {
    margin: 28px 0;
    padding: 20px 22px;
    border: 1px solid var(--rule);
    border-radius: 10px;
    background: var(--paper);
  }
  .mdx-feynman__label { margin: 0 0 10px; }
  .mdx-feynman__prompt {
    font-size: 15px;
    color: var(--ink);
    margin-bottom: 20px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--rule);
  }
  .mdx-feynman__editor { margin-top: 4px; }
</style>
