---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSession } from '../../lib/auth';

export const prerender = false;

const session = await getSession(Astro.request.headers);
if (!session?.user?.id) {
  return Astro.redirect(`/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}
---

<BaseLayout title="Explain it back — QA Learning" description="Feynman self-explanation exercises for every concept you have reviewed." noindex>
  <main class="explain-index">
    <header class="explain-index__head">
      <span class="eyebrow">feynman technique · self-explanation</span>
      <h1>Explain it back</h1>
      <p class="explain-index__lead">
        Pick a concept you have reviewed and explain it in plain language — as if you were teaching someone who has never heard of it.
      </p>
    </header>

    <p class="explain-index__hint">
      Navigate to <strong>/explain/[concept-slug]</strong> to start an explanation session for a specific concept.
    </p>
  </main>
</BaseLayout>

<style>
  .explain-index {
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }
  .explain-index__head {
    margin-bottom: 28px;
  }
  .explain-index__head h1 {
    font-family: var(--serif);
    font-size: 48px;
    font-weight: 400;
    letter-spacing: -0.03em;
    margin: 8px 0 0;
    color: var(--ink);
    line-height: 1.05;
  }
  .explain-index__lead {
    font-size: 16px;
    color: var(--ink-2);
    line-height: 1.65;
    margin: 16px 0 0;
    max-width: 560px;
  }
  .explain-index__hint {
    font-size: 14px;
    color: var(--ink-3);
    font-family: var(--mono);
    padding: 14px 18px;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 8px;
    margin: 0;
  }
</style>
