---
import '../styles/global.css';
import { ThemeToggle } from '../components/ThemeToggle';
import SearchModal from '../components/search/SearchModal';
import SearchTrigger from '../components/search/SearchTrigger';
import { AuthNav } from '../components/AuthNav';
import { SessionMerge } from '../components/SessionMerge';
import MobileNavToggle from '../components/nav/MobileNavToggle';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Footer from '../components/Footer.astro';
import interTightLatinUrl from '@fontsource-variable/inter-tight/files/inter-tight-latin-wght-normal.woff2?url';
import newsreaderLatinUrl from '@fontsource-variable/newsreader/files/newsreader-latin-opsz-normal.woff2?url';
import jetbrainsMonoLatinUrl from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url';
import { OG_WIDTH, OG_HEIGHT } from '../lib/og/generate';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  /** Path or absolute URL of the OG/Twitter image. Resolved against Astro.site. */
  image?: string;
  /** Structured data objects to emit as application/ld+json. Can be a single object or array. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Interactive study site for QA fundamentals — lessons, quizzes, and more.',
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  image = '/og/default.png',
  jsonLd,
} = Astro.props;

const imageUrl = new URL(image, Astro.site ?? Astro.url).href;
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const path = Astro.url.pathname;
const isLessons = path.startsWith('/lessons');
const isProjects = path.startsWith('/projects');
const isProfile = path.startsWith('/profile');

const navLinks = [
  { href: '/lessons', label: 'Lessons', active: isLessons },
  { href: '/projects', label: 'Build', active: isProjects },
  { href: '/profile', label: 'Profile', active: isProfile },
];
---

<html lang="en" class="min-h-screen">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Font preloads: above-the-fold faces only (latin, normal, opsz/wght axes) -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href={interTightLatinUrl} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={newsreaderLatinUrl} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={jetbrainsMonoLatinUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="QA Learning" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content={String(OG_WIDTH)} />
    <meta property="og:image:height" content={String(OG_HEIGHT)} />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@qalearning" />
    <meta name="twitter:creator" content="@qalearning" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Structured data -->
    {jsonLdArray.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme =
          stored ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <script>
      import { registerGlobalErrorHandlers } from '../lib/observability/client-reporter';
      registerGlobalErrorHandlers();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <header class="nav">
      <a class="nav__brand" href="/">
        <span class="nav__mark">qa</span>
        <span>QA&nbsp;Learning</span>
      </a>
      <nav class="nav__links" aria-label="Primary">
        <a href="/lessons" class={isLessons ? 'is-active' : ''}>Lessons</a>
        <a href="/projects" class={isProjects ? 'is-active' : ''}>Build</a>
        <a href="/profile" class={isProfile ? 'is-active' : ''}>Profile</a>
      </nav>
      <div class="nav__right">
        <MobileNavToggle client:media="(max-width: 767px)" links={navLinks} />
        <SearchTrigger client:load />
        <ThemeToggle client:load />
        <AuthNav client:load />
      </div>
    </header>
    <SearchModal client:only="react" />
    <SessionMerge client:idle />
    <slot />
    <slot name="footer"><Footer /></slot>
    <Analytics />
    <SpeedInsights />
  </body>
</html>
