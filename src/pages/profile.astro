---
import BaseLayout from '../layouts/BaseLayout.astro';
import { auth } from '../lib/auth';
import { getCompletedLessonCount } from '../db/queries';

export const prerender = false;

const session = await auth.api.getSession({ headers: Astro.request.headers });
const user = session?.user ?? null;
const completedCount = user?.id ? await getCompletedLessonCount(user.id) : 0;
---

<BaseLayout title="Profile — QA Learning">
  <main class="px-6 py-12 max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">Profile</h1>
    {user ? (
      <div class="space-y-4">
        <p class="text-gray-700 dark:text-gray-300">
          Signed in as <span class="font-medium">{user.name ?? user.email}</span>
        </p>
        <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-800">
          <div class="text-sm text-gray-500 dark:text-gray-400">Lessons completed</div>
          <div class="text-3xl font-semibold mt-1" data-testid="completed-count">{completedCount}</div>
        </div>
      </div>
    ) : (
      <p class="text-gray-700 dark:text-gray-300">Sign in to see your progress.</p>
    )}
  </main>
</BaseLayout>
