---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileShell from '../components/profile/ProfileShell';
import { getSession } from '../lib/auth';
import { loadProfile } from '../lib/profile/load-profile';
import { buildLessonMetaMap } from '../lib/curriculum/lesson-meta';
import { mockLoadProfile } from '../lib/test-auth-mock';
import { logError } from '../lib/observability/logger';

export const prerender = false;

let session: Awaited<ReturnType<typeof getSession>> = null;
try {
  session = await getSession(Astro.request.headers);
} catch (err) {
  logError('profile.astro SSR getSession', err, { route: '/profile', method: 'GET' });
}

let initialUser: { id: string; name?: string | null; email: string } | null = null;
let initialData: Awaited<ReturnType<typeof loadProfile>> | null = null;

if (session?.user?.id) {
  initialUser = {
    id: session.user.id,
    name: session.user.name ?? null,
    email: session.user.email,
  };

  try {
    if (process.env.E2E_OAUTH_MOCK === '1') {
      const lessonMetaMap = buildLessonMetaMap(await getCollection('curriculum'));
      initialData = mockLoadProfile(lessonMetaMap) as Awaited<ReturnType<typeof loadProfile>>;
    } else {
      const [projectEntries, curriculumEntries] = await Promise.all([
        getCollection('projects'),
        getCollection('curriculum'),
      ]);
      const projectTitleBySlug = new Map(projectEntries.map((p) => [p.data.slug, p.data.title]));
      const lessonMetaMap = buildLessonMetaMap(curriculumEntries);
      initialData = await loadProfile(session.user.id, { projectTitleBySlug, lessonMetaMap });
    }
  } catch (err) {
    logError('profile.astro SSR loadProfile', err, { route: '/profile', method: 'GET' });
    // Leave initialData null — ProfileShell will fall back to client fetch.
  }
}
---

<BaseLayout title="Profile — QA Learning">
  <main class="profile">
    <ProfileShell client:load initialUser={initialUser} initialData={initialData} />
  </main>
</BaseLayout>

<style>
  .profile {
    padding: 44px 56px;
    max-width: 1240px;
    margin: 0 auto;
  }
  @media (max-width: 768px) { .profile { padding: 28px 20px; } }

  :global(.identity) {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 16px;
  }
  :global(.identity__left) { display: flex; gap: 20px; align-items: center; }
  :global(.avatar--lg) { width: 64px; height: 64px; font-size: 22px; }
  :global(.identity__name) {
    font-family: var(--serif);
    font-size: 38px;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-top: 4px;
    color: var(--ink);
  }
  :global(.identity__email) {
    font-size: 13px;
    color: var(--ink-3);
    font-family: var(--mono);
    margin-top: 4px;
  }
  :global(.istat__num) {
    font-family: var(--serif);
    font-size: 44px;
    letter-spacing: -0.03em;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  :global(.istat__num-sub) { color: var(--ink-3); font-size: 24px; }

  :global(.profile-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
  }
  :global(.profile-grid__wide) { grid-column: 1 / -1; }
  @media (max-width: 1024px) { :global(.profile-grid) { grid-template-columns: 1fr; } }

  :global(.signed-out) { padding: 64px 0; }

  /* ── Retention lead (issue #386) ── */
  :global(.retention-lead) {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 20px 24px;
    margin-bottom: 16px;
  }
  :global(.retention-lead__header) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
  }
  :global(.retention-lead__link) {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  :global(.retention-lead__link:hover) { color: var(--ink); }
  :global(.retention-lead__stats) {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }
  :global(.retention-lead__stat) { display: flex; flex-direction: column; gap: 4px; }
  :global(.retention-lead__num) {
    font-family: var(--serif);
    font-size: 44px;
    letter-spacing: -0.03em;
    color: var(--ink);
    display: inline-flex;
    align-items: baseline;
    line-height: 1;
  }
  :global(.retention-lead__num-sub) { color: var(--ink-3); font-size: 24px; margin-left: 2px; }
  :global(.retention-lead__label) {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-3);
  }
  :global(.retention-lead__empty) {
    font-size: 13px;
    color: var(--ink-3);
    font-family: var(--mono);
    margin: 0;
  }

  /* ── Activity strip (issue #386) ── */
  :global(.activity-strip) {
    background: var(--paper-2);
    border: 1px dashed var(--rule);
    border-radius: 10px;
    padding: 16px 24px;
    margin-bottom: 24px;
  }
  :global(.activity-strip__label) {
    display: block;
    margin-bottom: 14px;
  }
  :global(.activity-strip__stats) {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }

  :global(.heatmap__header) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 14px;
  }
  :global(.heatmap__summary) {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
  }
  :global(.heatmap__scroll) {
    overflow-x: auto;
    padding-bottom: 4px;
  }
  :global(.heatmap__svg) { display: block; }
  :global(.heatmap__month-label),
  :global(.heatmap__dow-label) {
    font-family: var(--mono);
    font-size: 10px;
    fill: var(--ink-3);
  }
  :global(.heatmap__cell) {
    transition: stroke 80ms ease;
    cursor: pointer;
  }
  :global(.heatmap__cell:focus),
  :global(.heatmap__cell:hover) {
    outline: none;
    stroke: var(--ink);
    stroke-width: 1.5;
  }
  :global(.heatmap__cell--l0) { fill: var(--paper-3); }
  :global(.heatmap__cell--l1) { fill: oklch(82% 0.09 35); }
  :global(.heatmap__cell--l2) { fill: oklch(70% 0.14 35); }
  :global(.heatmap__cell--l3) { fill: oklch(56% 0.17 35); }
  :global(.heatmap__cell--l4) { fill: var(--accent-strong); }
  :global(.heatmap__footer) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 12px;
    flex-wrap: wrap;
    gap: 12px;
  }
  :global(.heatmap__tooltip) {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-2);
    min-height: 1.2em;
  }
  :global(.heatmap__legend) {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
  }
  :global(.heatmap__legend-cell) {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
    margin: 0 1px;
  }

  :global(.recent-activity) {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  :global(.recent-activity__row) {
    display: grid;
    grid-template-columns: 70px 1fr auto auto;
    align-items: baseline;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid var(--rule);
    font-size: 13px;
  }
  :global(.recent-activity__row:last-child) { border-bottom: none; }
  :global(.pill) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 2px 8px;
    border-radius: 99px;
    color: var(--ink-2);
    background: var(--paper-3);
  }
  :global(.pill--quiz) { background: oklch(94% 0.05 35); color: var(--accent-strong); }
  :global(.pill--project) { background: oklch(93% 0.06 220); color: oklch(38% 0.14 220); }
  :global(.recent-activity__title) {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  :global(.recent-activity__title:hover) { border-bottom-color: var(--ink-3); }
  :global(.recent-activity__meta) {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
  }
  :global(.recent-activity__time) {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    :global(.recent-activity__row) {
      grid-template-columns: 60px 1fr;
    }
    :global(.recent-activity__meta), :global(.recent-activity__time) {
      grid-column: 2;
    }
  }
</style>
