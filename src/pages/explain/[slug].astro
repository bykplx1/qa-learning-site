---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeynmanEditor from '../../components/explain/FeynmanEditor';
import { getSession } from '../../lib/auth';
import { curriculumTitleBySlug, slugToTitle } from '../../lib/curriculum/title-by-slug';

export const prerender = false;

const { slug } = Astro.params as { slug: string };

const curriculumEntries = await getCollection('curriculum');
const topicTitle = slugToTitle(slug, curriculumTitleBySlug(curriculumEntries));

const session = await getSession(Astro.request.headers);
if (!session?.user?.id) {
  return Astro.redirect(`/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

// Pass as a plain boolean prop — never expose the key itself to the island.
const showGapPrompt = process.env.FEATURE_AI_GAP_PROMPT === '1';
---

<BaseLayout title={`Explain: ${topicTitle} — QA Learning`} description="Feynman self-explanation exercise." noindex>
  <main class="explain-page">
    <header class="explain-page__head">
      <span class="eyebrow">feynman · self-explanation</span>
      <h1>{topicTitle}</h1>
    </header>

    <div class="explain-card card" data-testid="explain-card">
      <FeynmanEditor
        client:load
        conceptSlug={slug}
        wordTarget={150}
        showGapPrompt={showGapPrompt}
      />
    </div>
  </main>
</BaseLayout>

<style>
  .explain-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }
  .explain-page__head {
    margin-bottom: 28px;
  }
  .explain-page__head h1 {
    font-family: var(--serif);
    font-size: 42px;
    font-weight: 400;
    letter-spacing: -0.03em;
    margin: 8px 0 0;
    color: var(--ink);
    line-height: 1.1;
  }

  .explain-card {
    padding: 28px;
  }

  .explain-notice {
    padding: 10px 14px;
    background: var(--warn-soft, var(--accent-soft));
    border: 1px solid var(--warn, var(--rule));
    border-radius: 8px;
    font-size: 13px;
    color: var(--ink-2);
    margin-bottom: 20px;
  }

  .soft-block {
    max-width: 520px;
    margin: 0 auto;
    padding: 48px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .soft-block__icon {
    color: var(--accent);
  }
  .soft-block__title {
    font-family: var(--serif);
    font-size: 28px;
    font-weight: 400;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--ink);
  }
  .soft-block__body {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0;
    max-width: 420px;
  }
  .soft-block__actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
    max-width: 300px;
    margin-top: 8px;
  }
</style>
